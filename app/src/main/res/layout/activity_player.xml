<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/player_container" android:layout_width="match_parent"
    android:layout_height="match_parent" android:background="#000000" android:keepScreenOn="true">
    <androidx.media3.ui.PlayerView android:id="@+id/player_view"
        android:layout_width="match_parent" android:layout_height="match_parent"
        app:use_controller="false"/>
    <ProgressBar android:id="@+id/loading" android:layout_width="48dp" android:layout_height="48dp"
        android:layout_gravity="center" android:indeterminateTint="#E8420A"/>
    <TextView android:id="@+id/tv_error" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_gravity="center"
        android:textColor="#888888" android:textSize="13sp" android:gravity="center"
        android:padding="32dp" android:visibility="gone"/>
    <LinearLayout android:id="@+id/controls" android:layout_width="match_parent"
        android:layout_height="match_parent" android:orientation="vertical">
        <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:background="#CC000000">
            <Button android:id="@+id/btn_back" android:layout_width="wrap_content"
                android:layout_height="36dp" android:text="&#8592; Назад"
                android:textColor="#FFFFFF" android:textSize="11sp" android:background="#55000000"
                android:layout_marginEnd="14dp"/>
            <TextView android:id="@+id/tv_ch" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:textColor="#FFFFFF"
                android:textSize="14sp" android:textStyle="bold" android:singleLine="true"
                android:ellipsize="end"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:background="#CC000000">
            <Button android:id="@+id/btn_rw" android:layout_width="wrap_content"
                android:layout_height="40dp" android:text="&#10218; 10" android:textColor="#AAAAAA"
                android:textSize="13sp" android:background="@android:color/transparent"/>
            <Button android:id="@+id/btn_pp" android:layout_width="wrap_content"
                android:layout_height="44dp" android:text="&#9208;" android:textColor="#FFFFFF"
                android:textSize="24sp" android:background="@android:color/transparent"/>
            <Button android:id="@+id/btn_ff" android:layout_width="wrap_content"
                android:layout_height="40dp" android:text="10 &#10219;" android:textColor="#AAAAAA"
                android:textSize="13sp" android:background="@android:color/transparent"/>
            <TextView android:id="@+id/tv_time" android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:textColor="#555555"
                android:textSize="10sp" android:gravity="end"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>