<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="72dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingStart="16dp" android:paddingEnd="16dp">
    <TextView android:id="@+id/tv_emoji" android:layout_width="48dp" android:layout_height="48dp"
        android:gravity="center" android:textSize="22sp" android:background="#1A1A22"
        android:layout_marginEnd="14dp"/>
    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
        android:layout_height="wrap_content" android:orientation="vertical">
        <TextView android:id="@+id/tv_name" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#E4E4E4"
            android:textSize="14sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_now" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="#666666"
            android:textSize="11sp" android:singleLine="true" android:ellipsize="end"
            android:layout_marginTop="2dp"/>
    </LinearLayout>
    <TextView android:id="@+id/tv_num" android:layout_width="28dp"
        android:layout_height="wrap_content" android:textColor="#333333"
        android:textSize="10sp" android:gravity="end"/>
</LinearLayout>